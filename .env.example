# =============================================================================
# Løkka Pet Care — Environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and paste your real Supabase keys below.
# You get all of these from: Supabase dashboard > Project Settings > API
# NEVER commit `.env.local` (it is gitignored).
# =============================================================================

# ---- Public (safe to expose to the browser) --------------------------------
# >>> INSERT YOUR SUPABASE PROJECT URL HERE <<<
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# >>> INSERT YOUR SUPABASE ANON / PUBLISHABLE KEY HERE <<<
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-public-key

# ---- Server only (KEEP SECRET — never prefix with NEXT_PUBLIC) --------------
# Used by admin server actions and the create-admin script to bypass RLS.
# >>> INSERT YOUR SUPABASE SERVICE ROLE KEY HERE <<<
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-secret-key

# ---- App config -------------------------------------------------------------
# Base URL of the running app (used for absolute links / redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# FUTURE INTEGRATIONS (not used yet — left here so you know where they go)
# =============================================================================
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# VIPPS_CLIENT_ID=
# VIPPS_CLIENT_SECRET=
